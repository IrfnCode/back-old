PORT=3333
NODE_ENV=development
BRIDGE_SECRET=

SSO_USERNAME=
SSO_PASSWORD=
SSO_TOTP_SECRET=

# =======================
# Indonesia Proxy (ProxyScrape free list)
# Needed when VPS is outside ID (e.g. Germany) and Telkom blocks direct access
# =======================
PROXY_ENABLED=true
# Optional fixed proxy (skips auto list). Example: http://103.x.x.x:8080
# PROXY_URL=
# PROXY_TEST_URL=https://oss-incident.telkom.co.id
# PROXY_MAX_PROBE=12
# PROXY_LIST_TTL_MS=300000
# PROXY_API_URL=https://api.proxyscrape.com/v4/free-proxy-list/get?request=display_proxies&proxy_format=protocolipport&format=text&country=id

# =======================
# PELANTAR BOT
# =======================
INFRA_BOT_TOKEN=
INFRA_GROUP_ODP=
